# Нужно скопировать этот файл в .env и заполнить своими значениями:
#   cp .env.example .env

# База данных PostgreSQL
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=product_matcher

# SQLAlchemy подключение (используется бэкендом)
# Формат: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@db:5432/product_matcher

# Планировщик скраперов
# SCRAPE_ENABLED=true          — включить/выключить (true по умолчанию)
# SCRAPE_CRON=0 2 * * *        — расписание в cron-формате (по умолчанию: 1-го числа каждого месяца в 02:00)
SCRAPE_ENABLED=true
SCRAPE_CRON= 0 2 1 * *
